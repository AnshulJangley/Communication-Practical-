f=1000;
t = 0:1/f:1;
//modulating signal
fm = 5;
am = 3;
m = am* cos(2 * %pi *t*fm);
//carrier signal 
fc = 20;
ac = 3;
c =ac * cos(2 *%pi * fc*t);
//amplitude modulation
amp = (ac + m).*cos(2 *%pi *fc *t);

subplot(3,1,1);
plot(t,m);
title(" Modulating sig.");

subplot(3,1,2);
plot(t,c);
title(" Carrier sig.");
subplot(3,1,3);
plot(t,amp);
title(" amp Modulated sig.");
